{
  "name": "file-browser-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install",
    "dev": "concurrently \"DATABASE_NAME=$(pwd)/test-data/test.db npm run dev --prefix backend\" \"npm start --prefix frontend\"",
    "build": "npm run build --prefix frontend && npm run build --prefix backend",
    "start": "node backend/dist/server.js",
    "ingest": "npm run ingest --prefix ingester --",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "workspaces": [
    "frontend",
    "backend",
    "ingester"
  ],
  "devDependencies": {
    "@eslint/js": "^9.2.0",
    "concurrently": "^8.2.0",
    "eslint": "^9.2.0",
    "eslint-plugin-react": "^7.34.1",
    "globals": "^15.2.0",
    "typescript-eslint": "^8.5.0"
  }
}
